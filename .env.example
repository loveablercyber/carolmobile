# Supabase e opcional/legado no frontend. O app operacional usa /api + DATABASE_URL.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Somente backend/migrações. Nunca use DATABASE_URL no código do navegador.
DATABASE_URL=postgresql://usuario:senha@host:5432/carolmobile
JWT_SECRET=troque-por-um-segredo-longo
APP_URL=http://localhost:5173
# Opcional. Quando ausente, acompanha automaticamente o protocolo de APP_URL.
SESSION_COOKIE_SECURE=false

# E-mail (backend)
RESEND_API_KEY=
NOTIFICATION_EMAIL_FROM=CarolSol <carol.solsol@nextia.dev.br>
ADMIN_NOTIFICATION_EMAIL=

# WhatsApp/Baileys (backend)
BAILEYS_ENABLED=false
BAILEYS_API_URL=https://evo.nextia.dev.br
BAILEYS_API_KEY=
BAILEYS_WEBHOOK_SECRET=
BAILEYS_DEFAULT_INSTANCE=carol-sol

# OpenAI Responses API (somente backend)
OPENAI_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# SumUp (backend)
SUMUP_ENABLED=false
SUMUP_API_KEY=
SUMUP_MERCHANT_CODE=
SUMUP_ENVIRONMENT=sandbox
SUMUP_RETURN_URL=http://localhost:5173/cliente/pagamento/retorno
SUMUP_WEBHOOK_SECRET=

# Renovação automática: usa a mesma SUMUP_API_KEY acima. Permanece desligada por padrão.
SUMUP_RECURRING_ENABLED=false
SUMUP_RECURRING_MODE=disabled
RECURRING_BATCH_LIMIT=5
CRON_SECRET=

# Uploads (backend). JSON com objetos name, cloudName, apiKey e apiSecret.
# Nunca use prefixo VITE_ nestas variáveis.
CLOUDINARY_PROVIDERS_JSON=[]
CLOUDINARY_DEFAULT_FOLDER=carol-sol
